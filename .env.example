# =============================================================================
# Local-only secrets. Copy this file to ".env" and fill in real values.
# NEVER commit .env. The .gitignore at the project root already excludes it.
# =============================================================================

# --- Dropbox ---
# OAuth2 refresh-token flow is preferred (the refresh token doesn't expire).
# All three values come from your Dropbox app at
# https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your_dropbox_app_key_here
DROPBOX_APP_SECRET=your_dropbox_app_secret_here
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token_here

# Legacy fallback: a long-lived access token. Only one of (refresh+app_key+app_secret)
# OR (access_token) is needed. The refresh-token flow is more secure.
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# Where uploads should land in Dropbox. Vendor scripts append a per-vendor
# sub-folder underneath this. Default: /Billing_Refactoring_2026
DROPBOX_BASE_FOLDER=/Billing_Refactoring_2026

# --- AI fallback (Phase 1H foundation; disabled by default) ---
# The web app's optional AI assistance layer reads these. The CLI does not.
# When AI_FALLBACK_ENABLED is false (the default), no provider call ever
# fires regardless of which key is present. To enable, set both
# AI_FALLBACK_ENABLED=true AND AI_PROVIDER + the matching <PROVIDER>_API_KEY.
AI_FALLBACK_ENABLED=false

# Provider name. Must match an adapter in
# webapp/backend/services/ai_fallback.py:_PROVIDER_ADAPTERS.
# One of: disabled | openai | anthropic | google_gemini | deepseek
AI_PROVIDER=disabled

# Provider API keys — uncomment exactly the one matching AI_PROVIDER. Never
# commit real keys; .env is .gitignored.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# DEEPSEEK_API_KEY=...

# --- Phase 3.9C provider capability validation (disabled until probed) ---
# These identifiers are deployment configuration, not proof of capability.
# Use only a model identifier actually provisioned by the selected provider.
# The validator announces a capability only after its runtime probe passes.
# AI_ASSIST_ENABLED=false
# AI_PROVIDER=openai_compatible
# AI_MODEL=<configured-text-model-id>
# AI_API_KEY=<local-secret>
# AI_BASE_URL=<provider-endpoint>
# AI_TIMEOUT_SECONDS=45
# AI_VISION_ENABLED=false
# AI_VISION_PROVIDER=openai_compatible
# AI_VISION_MODEL=<configured-multimodal-model-id>
# AI_VISION_API_KEY=<local-secret-or-omit-to-reuse-AI_API_KEY>
# AI_VISION_BASE_URL=<provider-endpoint-or-omit-to-reuse-AI_BASE_URL>
# Optional native-PDF escalation for difficult scanned documents. This route
# preserves the original PDF, uses Responses structured output, and remains
# separate from the inexpensive digital-PDF/text path.
# AI_VISION_NATIVE_PDF_ENABLED=false
# AI_VISION_NATIVE_PDF_DETAIL=high
# AI_VISION_NATIVE_PDF_REASONING_EFFORT=high
# AI_VISION_NATIVE_PDF_MAX_BYTES=52428800
# AI_VISION_NATIVE_PDF_MAX_RESPONSE_TOKENS=32768
# AI_VISION_NATIVE_PDF_TIMEOUT_SECONDS=240
# AI_VISION_ESCALATION_MODEL=<provisioned-strong-multimodal-model-id>
# AI_VISION_ESCALATION_INPUT_COST_USD_PER_MILLION=<current-input-rate>
# AI_VISION_ESCALATION_OUTPUT_COST_USD_PER_MILLION=<current-output-rate>
# AI_VERIFICATION_PROVIDER=openai_compatible
# AI_VERIFICATION_MODEL=<configured-verification-model-id>
# AI_VERIFICATION_API_KEY=<local-secret-or-omit-to-reuse-AI_API_KEY>
# AI_VERIFICATION_BASE_URL=<provider-endpoint-or-omit-to-reuse-AI_BASE_URL>
# AI_ACCOUNTING_REASONING_PROVIDER=openai_compatible
# AI_ACCOUNTING_REASONING_MODEL=<configured-reasoning-model-id>
# AI_ACCOUNTING_REASONING_API_KEY=<local-secret-or-omit-to-reuse-AI_API_KEY>
# AI_ACCOUNTING_REASONING_BASE_URL=<provider-endpoint-or-omit-to-reuse-AI_BASE_URL>
# Optional explicit family identifiers support honest same-family reporting.
# AI_MODEL_FAMILY=<deployment-owned-family-id>
# AI_VISION_MODEL_FAMILY=<deployment-owned-family-id>
# AI_VERIFICATION_MODEL_FAMILY=<deployment-owned-family-id>
# AI_ACCOUNTING_REASONING_MODEL_FAMILY=<deployment-owned-family-id>
#
# --- Cost-optimized multi-provider profiles ---
# A credential alone never activates a profile. Set an explicit model ID and
# run the private capability validator first. Provider-specific profiles are
# ineligible for traffic until their profile IDs occur in the healthy probe
# report referenced by AI_PROVIDER_CAPABILITY_REPORT.
#
# Gemini (OpenAI-compatible endpoint default is built in)
# GEMINI_API_KEY=<local-secret>
# GEMINI_TEXT_MODEL=<provisioned-text-model-id>
# GEMINI_VISION_MODEL=<provisioned-vision-model-id>
# GEMINI_VERIFICATION_MODEL=<provisioned-verification-model-id>
# GEMINI_ACCOUNTING_REASONING_MODEL=<provisioned-reasoning-model-id>
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_INPUT_COST_USD_PER_MILLION=<current-input-rate>
# GEMINI_OUTPUT_COST_USD_PER_MILLION=<current-output-rate>
# GEMINI_TEXT_INPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# GEMINI_TEXT_OUTPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# GEMINI_VISION_INPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# GEMINI_VISION_OUTPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# GEMINI_ROUTING_PRIORITY=20
#
# DeepSeek (configure only capabilities supported by the deployed model)
# DEEPSEEK_API_KEY=<local-secret>
# DEEPSEEK_TEXT_MODEL=<provisioned-text-model-id>
# DEEPSEEK_VISION_MODEL=<provisioned-vision-model-id-if-supported>
# DEEPSEEK_VERIFICATION_MODEL=<provisioned-verification-model-id>
# DEEPSEEK_ACCOUNTING_REASONING_MODEL=<provisioned-reasoning-model-id>
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_INPUT_COST_USD_PER_MILLION=<current-input-rate>
# DEEPSEEK_OUTPUT_COST_USD_PER_MILLION=<current-output-rate>
# DEEPSEEK_ACCOUNTING_INPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# DEEPSEEK_ACCOUNTING_OUTPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# DEEPSEEK_ACCOUNTING_THINKING_ENABLED=false
# DEEPSEEK_ACCOUNTING_REASONING_EFFORT=medium
# DEEPSEEK_ROUTING_PRIORITY=30
#
# Anthropic / Claude (OpenAI-compatible adapter; strict JSON is validated
# locally because compatibility behavior differs from native structured output)
# ANTHROPIC_API_KEY=<local-secret>
# ANTHROPIC_TEXT_MODEL=<provisioned-text-model-id>
# ANTHROPIC_VISION_MODEL=<provisioned-vision-model-id>
# ANTHROPIC_VERIFICATION_MODEL=<provisioned-verification-model-id>
# ANTHROPIC_ACCOUNTING_REASONING_MODEL=<provisioned-reasoning-model-id>
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_INPUT_COST_USD_PER_MILLION=<current-input-rate>
# ANTHROPIC_OUTPUT_COST_USD_PER_MILLION=<current-output-rate>
# ANTHROPIC_VERIFICATION_INPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# ANTHROPIC_VERIFICATION_OUTPUT_COST_USD_PER_MILLION=<role-specific-current-rate>
# ANTHROPIC_ROUTING_PRIORITY=40
#
# Routing/cost safety. Profile IDs are examples of generated logical IDs;
# never add an ID here until its real probe is healthy.
# AI_PROVIDER_CAPABILITY_REPORT=<private-path-to-capability-report.json>
# AI_COST_ROUTING_VERIFIED_PROFILE_IDS=
# AI_TEXT_ROUTING_PROFILE_ID=<optional-healthy-profile-id>
# AI_VISION_ROUTING_PROFILE_ID=<optional-healthy-profile-id>
# AI_VISION_ESCALATION_MODEL=<optional-provisioned-strong-vision-model-id>
# AI_MAX_COST_PER_BATCH_USD=0.50
# AI_ESTIMATED_VISION_IMAGE_COST_USD=0.002
# AI_MAX_SEMANTIC_COST_PER_INVOICE_USD=0.08
# Maximum estimated provider cost for one operator chat interaction. The
# assistant fails closed before the request when this budget would be exceeded.
# AI_MAX_ACCOUNTING_ASSISTANT_COST_USD=0.02
# AI_SEMANTIC_REASONING_ENABLED=true
# --- Tenant accounting governance ---
# Local/development adapter until authenticated tenant claims own this value.
# Production fails closed when it is absent; never infer a customer tenant.
# INNER_VIEW_DEPLOYMENT_MODE=local
# INNER_VIEW_TENANT_ID=local-default
# Private visual probe evidence must remain outside Git.
# AI_CAPABILITY_VISION_PROBE_IMAGE=<private-data-url-or-authorized-reference>
# AI_CAPABILITY_VISION_PROBE_EXPECTED=<private-marker>
